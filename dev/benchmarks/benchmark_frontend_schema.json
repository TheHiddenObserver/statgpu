{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://statgpu.org/benchmark-frontend-schema.json",
  "title": "statgpu Benchmark Frontend Data Schema v1.1.0",
  "description": "Normalized benchmark data for the statgpu frontend dashboard.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated", "meta", "environments", "categories", "models", "frameworks", "comparisons", "runs"],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "generated": { "type": "string", "format": "date-time" },
    "meta": {
      "type": "object", "additionalProperties": false,
      "required": ["generator", "git_sha", "generation_id"],
      "properties": {
        "generator": { "type": "string" },
        "git_sha": { "type": "string" },
        "generation_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "environments": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["env_id", "label", "gpu", "cpu"],
        "properties": {
          "env_id": { "type": "string" },
          "label": { "type": "string" },
          "gpu": { "type": "string" },
          "cpu": { "type": "string" },
          "host": { "type": "string" }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["category_id", "name_zh", "name_en"],
        "properties": {
          "category_id": { "type": "string" },
          "name_zh": { "type": "string" },
          "name_en": { "type": "string" }
        }
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["model_id", "primary_category_id", "category_ids"],
        "properties": {
          "model_id": { "type": "string" },
          "primary_category_id": { "type": "string" },
          "category_ids": { "type": "array", "items": { "type": "string" } },
          "supports_penalty": { "type": "boolean", "default": false },
          "supports_inference": { "type": "boolean", "default": false }
        }
      }
    },
    "frameworks": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["framework_id", "display_name", "external", "backend_policy"],
        "properties": {
          "framework_id": { "type": "string" },
          "display_name": { "type": "string" },
          "external": { "type": "boolean" },
          "backend_policy": { "type": "string", "enum": ["required", "forbidden", "optional"] },
          "color": { "type": "string" }
        }
      }
    },
    "comparisons": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["comparison_id", "label", "env_id"],
        "properties": {
          "comparison_id": { "type": "string" },
          "label": { "type": "string" },
          "env_id": { "type": "string" }
        }
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["run_id", "env_id", "category_ids", "model_id",
                      "framework", "backend", "scale", "source", "comparison_id", "case_id", "method_config_id"],
        "properties": {
          "run_id": {
            "type": "string",
            "anyOf": [
              {"pattern": "^[0-9a-f]{16}$"},
              {"pattern": "^[a-z0-9][a-z0-9_.:-]*$"}
            ]
          },
          "benchmark_session_id": { "type": ["string", "null"] },
          "env_id": { "type": "string" },
          "category_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "model_id": { "type": "string" },
          "loss": { "type": "string" },
          "penalty": { "type": ["string", "null"] },
          "solver": { "type": "string" },
          "solver_display": { "type": "string" },
          "solver_kind": { "type": ["string", "null"], "enum": ["dispatch", "manual", "internal", null] },
          "comparison_id": { "type": "string" },
          "case_id": {
            "type": "string",
            "anyOf": [
              {"const": "default"},
              {"pattern": "^case-[0-9a-f]{16}$"},
              {"pattern": "^legacy-[0-9a-f]{16}$"}
            ]
          },
          "method_config_id": {
            "type": "string",
            "anyOf": [
              {"const": "default"},
              {"pattern": "^method-[0-9a-f]{16}$"},
              {"pattern": "^legacy-[0-9a-f]{16}$"}
            ]
          },
          "variant": { "type": ["string", "null"] },
          "implementation": { "type": ["string", "null"] },
          "parameters": { "type": "object" },
          "replicate": {
            "type": "object", "additionalProperties": false,
            "required": ["n_runs"],
            "properties": {
              "n_runs": { "type": "integer", "minimum": 1 },
              "seed_count": { "type": "integer", "minimum": 1 },
              "n_failed": { "type": "integer", "minimum": 0 }
            }
          },
          "framework": { "type": "string" },
          "backend": { "type": ["string", "null"], "enum": ["numpy", "cupy", "torch", null] },
          "scale": {
            "type": "object", "additionalProperties": false,
            "required": ["scale_key", "n_samples", "n_features", "label"],
            "properties": {
              "scale_key": { "type": "string" },
              "n_samples": { "type": "integer", "minimum": 1 },
              "n_features": { "type": "integer", "minimum": 1 },
              "label": { "type": "string" }
            }
          },
          "source": {
            "type": "object", "additionalProperties": false,
            "required": ["source_id", "file", "date", "parser", "parser_version"],
            "properties": {
              "source_id": {
                "type": "string",
                "anyOf": [
                  {"pattern": "^transitional:.+$"},
                  {"pattern": "^[a-z0-9-]+-[0-9]{8}-[0-9a-f]{12}$"}
                ]
              },
              "file": { "type": "string" },
              "original_path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "date": { "type": "string" },
              "parser": { "type": "string" },
              "parser_version": { "type": "string" }
            }
          },
          "metrics": {
            "type": "object", "additionalProperties": false,
            "properties": {
              "timing": {
                "type": "object", "additionalProperties": false,
                "required": ["fit_time_ms", "quality", "source_file"],
                "properties": {
                  "fit_time_ms": { "type": "number", "exclusiveMinimum": 0 },
                  "std_ms": { "type": "number", "minimum": 0 },
                  "min_ms": { "type": "number", "minimum": 0 },
                  "max_ms": { "type": "number", "minimum": 0 },
                  "sample_count": { "type": "integer", "minimum": 1 },
                  "std_ddof": { "type": "integer", "enum": [0, 1] },
                  "std_scope": { "type": "string", "enum": ["raw_measurements", "replicates"] },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "speedup": {
                "type": "object", "additionalProperties": false,
                "required": ["value", "reference_backend", "reference_framework", "reported_semantics", "quality", "source_file"],
                "properties": {
                  "value": { "type": "number", "minimum": 0 },
                  "reference_run_id": { "type": "string" },
                  "reference_backend": { "type": ["string", "null"], "enum": ["numpy", "cupy", "torch", null] },
                  "reference_framework": { "type": "string" },
                  "reported_semantics": { "type": "string", "enum": ["computed", "reported_by_runner"] },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "accuracy": {
                "type": "object", "additionalProperties": false,
                "required": ["quality", "source_file"],
                "properties": {
                  "coef_l2_diff": { "type": "number", "minimum": 0 },
                  "coef_l2_diff_std": { "type": "number", "minimum": 0 },
                  "coef_max_abs_diff": { "type": "number", "minimum": 0 },
                  "coef_max_abs_diff_std": { "type": "number", "minimum": 0 },
                  "coef_l2_rel_error": { "type": "number", "minimum": 0 },
                  "coef_l2_rel_error_std": { "type": "number", "minimum": 0 },
                  "bse_max_abs_diff": { "type": "number", "minimum": 0 },
                  "bse_max_abs_diff_std": { "type": "number", "minimum": 0 },
                  "reference": { "type": "string" },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "inference": {
                "type": "object", "additionalProperties": false,
                "required": ["quality", "source_file"],
                "properties": {
                  "bse": { "type": "number", "minimum": 0 },
                  "wald_stat": { "type": "number" },
                  "p_value": { "type": "number", "minimum": 0, "maximum": 1 },
                  "ok": { "type": "boolean" },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "convergence": {
                "type": "object", "additionalProperties": false,
                "properties": {
                  "n_iter_mean": { "type": "number", "minimum": 0 },
                  "n_iter_std": { "type": "number", "minimum": 0 },
                  "converged_rate": { "type": "number", "minimum": 0, "maximum": 1 },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "selection": {
                "type": "object", "additionalProperties": false,
                "required": ["quality", "source_file"],
                "properties": {
                  "precision": { "type": "number", "minimum": 0, "maximum": 1 },
                  "precision_std": { "type": "number", "minimum": 0 },
                  "recall": { "type": "number", "minimum": 0, "maximum": 1 },
                  "recall_std": { "type": "number", "minimum": 0 },
                  "fdp": { "type": "number", "minimum": 0, "maximum": 1 },
                  "fdp_std": { "type": "number", "minimum": 0 },
                  "f1": { "type": "number", "minimum": 0, "maximum": 1 },
                  "f1_std": { "type": "number", "minimum": 0 },
                  "jaccard_truth": { "type": "number", "minimum": 0, "maximum": 1 },
                  "jaccard_truth_std": { "type": "number", "minimum": 0 },
                  "estimated_fdr": { "type": "number", "minimum": 0, "maximum": 1 },
                  "estimated_fdr_std": { "type": "number", "minimum": 0 },
                  "target_fdr": { "type": "number", "minimum": 0, "maximum": 1 },
                  "n_selected_mean": { "type": "number", "minimum": 0 },
                  "n_selected_std": { "type": "number", "minimum": 0 },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "prediction": {
                "type": "object", "additionalProperties": false,
                "required": ["quality", "source_file"],
                "properties": {
                  "train_mse": { "type": "number", "minimum": 0 },
                  "train_mse_std": { "type": "number", "minimum": 0 },
                  "test_mse": { "type": "number", "minimum": 0 },
                  "test_mse_std": { "type": "number", "minimum": 0 },
                  "test_mse_noiseless": { "type": "number", "minimum": 0 },
                  "test_mse_noiseless_std": { "type": "number", "minimum": 0 },
                  "c_index": { "type": "number", "minimum": 0, "maximum": 1 },
                  "c_index_std": { "type": "number", "minimum": 0 },
                  "alpha_mean": { "type": "number", "minimum": 0 },
                  "alpha_std": { "type": "number", "minimum": 0 },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              },
              "validation": {
                "type": "object", "additionalProperties": false,
                "required": ["status", "quality", "source_file"],
                "properties": {
                  "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
                  "checks": {
                    "type": "array",
                    "items": {
                      "type": "object", "additionalProperties": false,
                      "required": ["metric", "status"],
                      "properties": {
                        "metric": { "type": "string" },
                        "status": { "type": "string", "enum": ["pass", "warn", "fail"] },
                        "operator": { "type": "string", "enum": ["le", "lt", "ge", "gt", "abs_le"] },
                        "value": { "type": "number" },
                        "tolerance": { "type": "number", "minimum": 0 },
                        "reference": { "type": "string" }
                      }
                    }
                  },
                  "quality": { "type": "string", "enum": ["measured", "reported", "computed", "partial"] },
                  "source_file": { "type": "string" }
                }
              }
            }
          },
          "quality": {
            "type": "object", "additionalProperties": false,
            "properties": {
              "status": { "type": "string", "enum": ["ok", "warning", "error"] },
              "warnings": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}