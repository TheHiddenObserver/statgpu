{
  "name": "statgpu-benchmark-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "npm run typecheck:src",
    "typecheck:src": "tsc --noEmit -p tsconfig.json",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "typecheck:contract": "tsc --noEmit -p tsconfig.contract.json",
    "preview": "vite preview",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "echarts": "^5.6.0"
  }
}
